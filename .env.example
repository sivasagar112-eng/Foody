# Foody Environment Variables Example
# Copy this file to .env and fill in your values

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-public-anon-key
EXPO_PUBLIC_DATABASE_PASSWORD=your-database-password
EXPO_PUBLIC_USE_MOCK_DATA=true # Set to false to force using live Supabase backend
